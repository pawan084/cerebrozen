# CereBroZen — PRODUCTION secrets & config.
#
#   cp .env.production.example .env.production   # then fill in REAL values
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
# .env.production is git-ignored and must NEVER be committed. Generate every
# value FRESH for this deployment — do not reuse any secret from a reference
# project or a dev machine (those are treated as compromised).

# ── database ────────────────────────────────────────────────────────────────
# Postgres superuser password. Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_strong_random

# ── shared auth secret (engine + platform use the SAME one) ─────────────────
# Base64-encoded HS512 secret. The platform mints tokens the engine validates,
# so both services MUST share this exact value. Generate:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_base64_64_bytes

# ── coaching model ──────────────────────────────────────────────────────────
# A NEW OpenAI key for production (rotate/replace any key ever pasted in chat or
# committed to a dev .env). Get one at platform.openai.com/api-keys.
OPENAI_API_KEY=sk-proj-CHANGE_ME
# Model override. LEAVE THIS BLANK unless your account cannot reach a model the
# workbook Catalog names — setting it forces ONE model on every agent and discards
# the Catalog's per-agent choice. It defaulted to gpt-5-mini until 2026-07-17;
# measured, that was 3.6x slower AND 1.7x more expensive per cached turn, because
# mini spends ~1,408 reasoning tokens/turn at output rates. See docs/EVALS.md.
CEREBROZEN_MODEL_OVERRIDE=

# ── marketing demo-request email (OPTIONAL) ─────────────────────────────────
# The demo form posts leads to the platform pipeline first; email is the
# fallback. Leave blank to skip email (the pipeline still captures the lead).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
DEMO_REQUEST_TO=hello@cerebrozen.in
