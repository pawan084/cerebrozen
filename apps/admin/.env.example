# CereBroZen admin portal — build-time configuration.
#
# NEXT_PUBLIC_* variables are inlined into the CLIENT bundle when `npm run
# build` runs. Setting them at runtime (container environment:) has NO effect
# on an already-built image — pass them as a Docker build arg instead (see
# Dockerfile / docker-compose.yml).
#
# Browser-side URL of the platform API: it must be reachable from the end
# user's machine (an HR admin's laptop), not from inside the container.
NEXT_PUBLIC_API_URL=http://localhost:8100

# The marketing site — where the wordmark and the login footer link back to.
# Prod default when unset is https://cerebrozen.in.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
