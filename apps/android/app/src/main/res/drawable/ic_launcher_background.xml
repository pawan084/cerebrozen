<?xml version="1.0" encoding="utf-8"?>
<!-- W24: deep night-indigo ground (the brand backdrop floor, 0xFF100D2B) with
     a whisper of indigo lift behind where the orb sits and a subtle darker
     vignette toward the corners — quiet depth, no pattern. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- The night floor. -->
    <path android:pathData="M0,0h108v108h-108z" android:fillColor="#FF100D2B" />

    <!-- A soft indigo lift behind the mark, slightly above centre. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="46"
                android:gradientRadius="58"
                android:startColor="#66231D50"
                android:endColor="#00231D50" />
        </aapt:attr>
    </path>

    <!-- Darker vignette settling into the corners. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="80"
                android:startColor="#00060414"
                android:endColor="#8C060414" />
        </aapt:attr>
    </path>
</vector>
