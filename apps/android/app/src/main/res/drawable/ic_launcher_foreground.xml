<?xml version="1.0" encoding="utf-8"?>
<!-- W24: the brand mark as the adaptive-icon foreground — the night orb inside
     the open C-ring (mirrors ui/Brand.kt BrandMark and the shared SVG at
     apps/web/public/brand/cerebro-mark.svg). Everything sits inside the 66dp
     safe circle of the 108dp adaptive canvas; the soft glow may bleed a little
     further (it is decorative and masks fine on every launcher shape). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft lavender bloom behind the whole mark. -->
    <path android:pathData="M54,54 m-30,0 a30,30 0 1,0 60,0 a30,30 0 1,0 -60,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="30"
                android:startColor="#4D8A7BF0"
                android:endColor="#008A7BF0" />
        </aapt:attr>
    </path>

    <!-- Open C-ring (gap on the right): arc from 52° to 308°, lavender→cyan. -->
    <path
        android:pathData="M65.7,68.97 A19,19 0 1 1 65.7,39.03"
        android:strokeWidth="5.2"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="35"
                android:startY="35"
                android:endX="76"
                android:endY="76"
                android:startColor="#FFCBB6FF"
                android:endColor="#FF8FE6EE" />
        </aapt:attr>
    </path>

    <!-- The glowing orb — lit from the upper left, settling into deep iris. -->
    <path android:pathData="M54,54 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="51.2"
                android:centerY="50.6"
                android:gradientRadius="15">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="0.33" android:color="#FFDFE0FF" />
                <item android:offset="0.72" android:color="#FF8A7BF0" />
                <item android:offset="1" android:color="#FF5B52C9" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Specular highlight, top-left of the orb. -->
    <path
        android:pathData="M50,49.8 m-2.2,0 a2.2,2.2 0 1,0 4.4,0 a2.2,2.2 0 1,0 -4.4,0"
        android:fillColor="#61FFFFFF" />
</vector>
