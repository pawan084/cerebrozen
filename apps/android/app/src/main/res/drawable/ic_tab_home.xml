<?xml version="1.0" encoding="utf-8"?>
<!-- W24 tab icon: rounded house with a tiny orb dot — thin rounded-line style
     (2dp stroke on a 24dp grid, shared across the whole tab set). Drawn in
     white; the Icon composable tints it per selection state. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Roof. -->
    <path
        android:pathData="M4.9,11 L12,4.9 L19.1,11"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Walls with a rounded floor. -->
    <path
        android:pathData="M6.7,9.9 L6.7,16.5 Q6.7,18.7 8.9,18.7 L15.1,18.7 Q17.3,18.7 17.3,16.5 L17.3,9.9"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- The orb at home. -->
    <path
        android:pathData="M12,13.6 m-1.7,0 a1.7,1.7 0 1,0 3.4,0 a1.7,1.7 0 1,0 -3.4,0"
        android:fillColor="#FFFFFFFF" />
