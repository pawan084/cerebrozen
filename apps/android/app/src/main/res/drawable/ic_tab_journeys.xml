<?xml version="1.0" encoding="utf-8"?>
<!-- Journeys tab icon: a compass — circle with a diamond needle. Same geometry
     as the web CompassIcon (icons.tsx), thin rounded-line style (2dp stroke on
     a 24dp grid, matching the W24 tab set). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:pathData="M12,12 m-8.2,0 a8.2,8.2 0 1 1 16.4,0 a8.2,8.2 0 1 1 -16.4,0"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Needle: NE-to-SW diamond, open. -->
    <path
        android:pathData="M15.2,8.8 L13.4,13.4 L8.8,15.2 L10.6,10.6 Z"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
