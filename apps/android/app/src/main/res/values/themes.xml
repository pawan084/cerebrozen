<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme; the real UI colors come from Compose (ui/theme). This keeps
         the system window background night-dark so there's no white flash. -->
    <style name="Theme.CereBro" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/night</item>
        <item name="android:statusBarColor">@color/night</item>
        <item name="android:navigationBarColor">@color/night</item>
    </style>
</resources>
