# Employee web app — the coaching experience in a browser (app.cerebrozen.in).
# Both are NEXT_PUBLIC_ → inlined into the client bundle at BUILD time.

# Platform API (auth, profile). Prod: https://api.cerebrozen.in
NEXT_PUBLIC_API_URL=http://localhost:8100

# Coaching engine (sessions/turns, SSE). Prod: https://api.cerebrozen.in/engine
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000

# The marketing site — where the wordmark and the login footer link back to.
# Prod default when unset is https://cerebrozen.in.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
