# SMTP credentials for the demo-request form (/api/demo).
# Use the mailbox that hosts hello@cerebrozen.in (Zoho, Google Workspace, etc.).
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=hello@cerebrozen.in
SMTP_PASS=app-password-here

# Where demo requests are delivered. Defaults to the site email if unset.
# DEMO_REQUEST_TO=hello@cerebrozen.in

# Server-side URL of the platform API — the demo form pipes leads into the
# ops-admin Demo tab through it (best-effort; email above is the fallback).
# In docker compose this is http://platform:8100; unset it falls back to
# http://localhost:8100 and piped leads silently stop outside a dev box.
PLATFORM_API_URL=http://localhost:8100

# Where the header "Sign in" menu sends people. OPTIONAL — the default already
# switches on the build: `next dev` links the local servers (:3002 / :3001),
# a production build links https://app.cerebrozen.in / https://admin.cerebrozen.in.
# Set these (inlined at BUILD time, NEXT_PUBLIC_) only to override — e.g. point a
# dev build at staging. The menu shows the host it will actually open, so a wrong
# value is visible on the page rather than only on the click.
# NEXT_PUBLIC_APP_URL=http://localhost:3002
# NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
