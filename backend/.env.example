# ── Core ────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ────────────────────────────────────────────────────────────
# For docker compose this is overridden to use the `db` service host.
DATABASE_URL=postgresql+asyncpg://cerebro:cerebro@localhost:5432/cerebro

# ── CORS (web + admin origins) ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── AI (proactive features) ─────────────────────────────────────────────
# Provider is chosen at runtime: OpenAI when OPENAI_API_KEY is set, else
# Anthropic, else deterministic local fallbacks (no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
# LangGraph agent (tool-calling + confirm-before-write streaming). Needs an LLM key.
ORACLE_ENABLED=false

# ── Voice (Deepgram STT + ElevenLabs TTS) ───────────────────────────────
# Leave a key blank to disable that half of the voice loop.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Push (APNs, token-based) ────────────────────────────────────────────
# Leave APNS_KEY_PATH blank to log pushes instead of sending.
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.cerebro.app
APNS_USE_SANDBOX=true

# ── Seed ────────────────────────────────────────────────────────────────
SEED_DEMO_DATA=true
ADMIN_EMAIL=admin@cerebro.app
ADMIN_PASSWORD=admin12345
