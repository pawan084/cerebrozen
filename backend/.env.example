# ── Core ────────────────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Base URL used in verification / password-reset email links.
APP_BASE_URL=https://cerebrozen.in

# ── Database ────────────────────────────────────────────────────────────
# For docker compose this is overridden to use the `db` service host.
DATABASE_URL=postgresql+asyncpg://cerebro:cerebro@localhost:5432/cerebro

# ── CORS (web + admin origins) ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ── AI (proactive features) ─────────────────────────────────────────────
# Provider is chosen at runtime: OpenAI when OPENAI_API_KEY is set, else
# Anthropic, else deterministic local fallbacks (no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
# LangGraph agent (tool-calling + confirm-before-write streaming). Needs an LLM key.
ORACLE_ENABLED=false

# ── Sign in with Apple / Google ─────────────────────────────────────────
# Token audiences. APPLE_CLIENT_ID falls back to APNS_BUNDLE_ID when blank.
# Leave GOOGLE_CLIENT_ID blank to skip audience checks in dev; set in prod.
APPLE_CLIENT_ID=
# Web Sign in with Apple Services ID (second accepted token audience).
APPLE_SERVICES_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ── Subscriptions (StoreKit 2 server-side receipt validation) ───────────
# Free-tier daily message cap enforced on /chat + /oracle (premium = unlimited).
FREE_DAILY_MESSAGES=50
# Path to Apple's Root CA (G3) PEM to PIN the receipt cert chain. Blank = verify
# the chain internally but skip pinning (dev only — set this in production; the
# cert ships at app/certs/AppleRootCA-G3.pem).
APPSTORE_ROOT_CERT_PATH=
APPSTORE_BUNDLE_ID=com.cerebrozen.app

# ── Proactive nudges ────────────────────────────────────────────────────
# Minutes between in-process delivery passes (0 = rely on an external cron
# hitting POST /admin/nudges/dispatch). Safe with multiple workers.
NUDGE_DISPATCH_INTERVAL_MINUTES=5

# ── Transactional email (verification, password reset, trusted contact) ──
# Blank SMTP_HOST = log emails instead of sending (dev). Set these to deliver.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CereBro <no-reply@cerebrozen.in>
SMTP_TLS=true

# ── Safety escalation ───────────────────────────────────────────────────
# Ops inbox alerted on crisis safety events (blank = log only).
OPS_ALERT_EMAIL=
# SMS (Twilio) for phone/SMS trusted-contact alerts (blank = log only).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Web billing (Stripe, apps/app) ──────────────────────────────────────
# Blank secret = /billing/checkout returns 503 and the webhook rejects.
# Point Stripe's webhook at POST /webhooks/stripe with the signing secret.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_ANNUAL=
STRIPE_PRICE_PREMIUM_HUMAN_MONTHLY=
STRIPE_PRICE_PREMIUM_HUMAN_ANNUAL=
STRIPE_RETURN_URL=https://app.cerebrozen.in/account

# ── Voice (Deepgram STT + ElevenLabs TTS) ───────────────────────────────
# Leave a key blank to disable that half of the voice loop.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Generated media (narration MP3s, served publicly at /media) ─────────
# Relative to the working dir (/app in-container). Dev bind-mount ⇒ files
# land in git-ignored backend/media/; prod mounts the named `media` volume.
MEDIA_ROOT=media

# ── Push (Web Push / VAPID, browser nudges on apps/app) ────────────────
# Self-generated keypair — no third-party account. Easiest (env-ready
# base64url strings): `npx web-push generate-vapid-keys`. (The py-vapid
# `vapid` CLI in the api container works too but emits PEM files.)
# Blank keys = the web client disables its notifications toggle; delivery logs.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@cerebrozen.in

# ── Push (APNs, token-based) ────────────────────────────────────────────
# Leave APNS_KEY_PATH blank to log pushes instead of sending.
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.cerebrozen.app
APNS_USE_SANDBOX=true

# ── Seed ────────────────────────────────────────────────────────────────
SEED_DEMO_DATA=true
ADMIN_EMAIL=admin@cerebro.app
ADMIN_PASSWORD=admin12345
