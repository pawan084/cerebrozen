# Production environment template.
#   cp backend/.env.production.example backend/.env.production   # then fill in
# NEVER commit the filled-in .env.production. The app refuses to boot in
# production with insecure defaults (see app/core/config._guard_production).

# ── Core ────────────────────────────────────────────────────────────────
ENV=production
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
LOG_LEVEL=INFO
WEB_CONCURRENCY=3          # gunicorn worker processes

# ── Database ────────────────────────────────────────────────────────────
# POSTGRES_* configure the db container; DATABASE_URL must match them and use
# the in-network host `db`.
POSTGRES_USER=cerebro
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=cerebro
DATABASE_URL=postgresql+asyncpg://cerebro:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/cerebro

# ── CORS (explicit prod origins; no wildcard) ───────────────────────────
CORS_ORIGINS=https://app.your-domain.com,https://admin.your-domain.com

# ── Seed / admin ────────────────────────────────────────────────────────
SEED_DEMO_DATA=false
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── AI (optional — blank ⇒ deterministic local fallbacks) ───────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8

# ── Voice (optional — blank ⇒ voice loop disabled) ──────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Push (APNs, optional) ───────────────────────────────────────────────
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.cerebro.app
APNS_USE_SANDBOX=false
