# Production environment template for CereBrozen.
#   cp backend/.env.production.example backend/.env.production   # then fill in
# NEVER commit the filled-in .env.production. The app refuses to boot in
# production with insecure defaults (see app/core/config._guard_production).

# ── Core ────────────────────────────────────────────────────────────────
ENV=production
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_VALUE_AT_LEAST_32_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
LOG_LEVEL=INFO
WEB_CONCURRENCY=3          # gunicorn worker processes
APP_BASE_URL=https://cerebrozen.in

# ── Database ────────────────────────────────────────────────────────────
# POSTGRES_* configure the db container; DATABASE_URL must match them and use
# the in-network host `db`.
POSTGRES_USER=cerebro
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=cerebro
DATABASE_URL=postgresql+asyncpg://cerebro:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/cerebro

# ── CORS (explicit prod origins; no wildcard) ───────────────────────────
CORS_ORIGINS=https://cerebrozen.in,https://www.cerebrozen.in,https://admin.cerebrozen.in

# ── Seed / admin ────────────────────────────────────────────────────────
SEED_DEMO_DATA=false
ADMIN_EMAIL=admin@cerebrozen.in
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── AI (blank ⇒ deterministic local fallbacks) ──────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
# LangGraph agent (tool-calling + streaming). Needs an LLM key.
ORACLE_ENABLED=true
FREE_DAILY_MESSAGES=50

# ── Voice (blank ⇒ that half of the loop is disabled) ───────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Sign in with Apple / Google ─────────────────────────────────────────
APPLE_CLIENT_ID=com.cerebrozen.app
GOOGLE_CLIENT_ID=

# ── Subscriptions (StoreKit 2 server-side validation) ───────────────────
APPSTORE_BUNDLE_ID=com.cerebrozen.app
# Path (inside the container) to Apple's Root CA (G3) PEM to pin the chain.
# The cert ships with the repo; leave this set in production.
APPSTORE_ROOT_CERT_PATH=app/certs/AppleRootCA-G3.pem

# ── Proactive nudges ────────────────────────────────────────────────────
# Minutes between in-process delivery passes (0 = rely on an external cron
# hitting POST /admin/nudges/dispatch instead). Safe with multiple workers.
NUDGE_DISPATCH_INTERVAL_MINUTES=5

# ── Transactional email (verification, reset, trusted contact) ──────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CereBro <no-reply@cerebrozen.in>
SMTP_TLS=true

# ── Safety escalation ───────────────────────────────────────────────────
OPS_ALERT_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Push (APNs, optional) ───────────────────────────────────────────────
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.cerebrozen.app
APNS_USE_SANDBOX=false
