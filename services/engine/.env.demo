# CereBroZen — demo environment.
#
#   cp .env.demo .env
#   docker compose up -d mongo redis        # the demo NEEDS Mongo (see below)
#   python -m scripts.seed_demo             # 4 synthetic users
#   uvicorn app.main:app --reload --port 8000
#
# Why Mongo is not optional here: the stores are Mongo-only. Without it they
# silently no-op, so no prior-session data can exist — and every interesting path
# (repeat user, 7-day action check-in, "what did you commit to last time") needs
# prior data to fire. A demo without Mongo can only ever show a fresh user's first
# turn.

# --- LLM ---------------------------------------------------------------------
# Leave OPENAI_API_KEY empty to run on the MOCK provider: the whole graph runs
# offline with deterministic canned replies. Perfect for demoing the FLOW (you see
# every node fire, instantly, for free). Set a real key when you want real coaching.
OPENAI_API_KEY=
CEREBROZEN_LLM_PROVIDER=openai

# --- Persistence -------------------------------------------------------------
MONGO_DB_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379/0
SQLITE_CHECKPOINT_PATH=./cerebrozen.db

# --- Prompts -----------------------------------------------------------------
PROMPT_SOURCE=codebase
PROMPT_WORKBOOK=agent_prompts.xlsx
# Real caching (version-hash busted). Demo prompts don't change mid-demo, so this
# is free latency + cost.
CEREBROZEN_LLM_PROMPT_CACHE=true

# --- Auth --------------------------------------------------------------------
# Local demo: no JWT. Never do this outside a demo box.
ENV=local
AUTH_DEV_BYPASS=true

# --- Features ----------------------------------------------------------------
# All three coaching paths live (CIM / CBT / CH), so the flow view can show the
# branch actually taken.
CEREBROZEN_ENABLE_MULTIPATH=true
CEREBROZEN_ENABLE_BUILDERS=true

# Uncomment to make every stage hand off after one turn — walks the WHOLE graph in
# a handful of messages. Ideal for showing the full flow end-to-end in 60 seconds;
# meaningless as coaching. Test-only.
# CEREBROZEN_FORCE_HANDOFF=__all__
