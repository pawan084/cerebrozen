# ─────────────────────────────────────────────────────────────
# CereBroZen LangGraph — environment configuration
# Copy to .env and fill in. Only OPENAI_API_KEY is strictly required;
# everything else has a safe local fallback (Article 10 — degrade gracefully).
# ─────────────────────────────────────────────────────────────

# --- LLM (required) ---
OPENAI_API_KEY=
OPENAI_TIMEOUT=60
OPENAI_STREAM_DEADLINE_S=180

# Right-sized models per node (Article 5.3)
CEREBROZEN_MODEL_COACHING=gpt-5-mini
CEREBROZEN_MODEL_FAST=gpt-5-nano
CEREBROZEN_MODEL_RAG=gpt-4o-mini
CEREBROZEN_MODEL_EMBED=text-embedding-3-small

# --- Postgres (PRIMARY storage: document stores via the pg shim, LangGraph
#     checkpointer, and pgvector RAG — all from this one URL) ---
# docker compose provides: postgresql://postgres:pg@localhost:55432/cerebrozen
POSTGRES_URL=

# RAG backend: defaults to pgvector when POSTGRES_URL is set.
# Set to "lancedb" to opt back into LanceDB/S3.
#CEREBROZEN_RAG_BACKEND=pgvector

# --- Local fallback when no Postgres: auto | memory | sqlite | mongo ---
# auto = mongo if MONGO_DB_URL set, else memory. Use "sqlite" for a durable local file.
DB_BACKEND=sqlite
SQLITE_PATH=./cerebrozen.db

# --- MongoDB (legacy deployments only; used when DB_BACKEND=mongo and no POSTGRES_URL) ---
MONGO_DB_URL=
MONGO_DB_NAME=cerebrozen

# --- Redis (per-session lock + profile cache). Empty => fakeredis ---
REDIS_URL=redis://localhost:6379/0

# --- Prompt registry workbook ---
# PROMPT_SOURCE: "codebase" (local file) or "s3" (download on reload)
PROMPT_SOURCE=codebase
# The workbook the registry loads. This is the ONLY var that selects it.
# (There used to be a PROMPT_WORKBOOK_PATH here that no code ever read — it pointed
#  at a second copy of the workbook, so edits to that copy silently did nothing.)
PROMPT_WORKBOOK=agent_prompts.xlsx
PROMPT_S3_BUCKET=
PROMPT_S3_KEY=agent_prompts.xlsx
# Prompt caching. false (default) prepends a random UUID to every system prompt, which
# guarantees a 0% cache hit rate — safe, but you re-pay for ~8-16K prompt tokens every
# turn. true stamps the workbook's content-hash version instead: the prefix is stable
# across requests (real cache hits) and a prompt reload changes the hash, so the reload
# busts the cache by itself. Prefer true outside local dev.
CEREBROZEN_LLM_PROMPT_CACHE=false

# --- RAG (LanceDB + S3). Empty RAG_S3_BUCKET => RAG disabled ---
RAG_URI=./.lancedb
RAG_S3_BUCKET=
RAG_REINDEX=false

# --- Auth (JWT, HS512) ---
# ENV gates the dev conveniences below. Anything that is not local/dev/development/test/ci
# is treated as a real deployment: AUTH_DEV_BYPASS is REFUSED there (logged as
# `auth.dev_bypass_refused`) and auth stays on. A stray bypass in a deployed env used to
# turn authentication off everywhere, silently — it cannot any more.
ENV=local
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS512
# Dev-only. Has no effect outside a development-class ENV — see above.
AUTH_DEV_BYPASS=true

# --- Rate limiting (app/ratelimit.py) ---
# Every coaching turn is a paid LLM call against a ~21K-token prompt, so the turn endpoint
# is the one place an ordinary retry storm becomes an extraordinary bill. Limits are keyed
# on the signed JWT subject (never the request body's user_id, which the caller controls).
# NOTE: without a shared REDIS_URL the counter lives in-process, so N instances allow N x
# the rate. Set REDIS_URL in any real deployment.
CEREBROZEN_RATE_LIMIT=true
CEREBROZEN_RATE_LIMIT_TURNS_PER_MIN=20
CEREBROZEN_RATE_LIMIT_STARTS_PER_HOUR=30

# --- Crisis screen (app/graph/crisis.py) ---
# The helpline shown when the screen trips. The default names no country (findahelpline.com
# routes internationally); a US 988 or a UK 116-123 is worse than useless in the wrong market.
CEREBROZEN_CRISIS_LINE=
# Optional JSON file of extra crisis phrases: {"latin": [...], "other": [...]}.
# The built-in lexicon spans ~20 languages but was NOT reviewed by native speakers. Before
# shipping into a language, have its phrase list reviewed and supply corrections here — an
# inaccurate list is worse than an absent one, because it looks like coverage.
CEREBROZEN_CRISIS_TERMS_FILE=
# Optional JSON file of crisis REPLIES per language: {"ja": "...", "zh": "..."}.
# Detection covers ~20 languages; the built-in replies are written in 7 (en/es/pt/fr/de/it/nl),
# so anything else is detected and answered in English. Watch for the ERROR log
# `crisis.reply_language_unavailable` — it names the language you need translated.
CEREBROZEN_CRISIS_MESSAGES_FILE=

# --- White-labelling: refuse to inherit the first client's infrastructure ---
# Several config defaults (MONGO_CHECKPOINT_DB, RAG_S3_BUCKET, MONGO_DB_BACKEND_DB, RASA_DB) name
# the FIRST tenant's real database and S3 bucket. They are not renamed on purpose: renaming a
# default does not rename the resource, it just orphans every checkpointed session.
#
# A second tenant sets this to true. Any setting still at an incumbent default then becomes a HARD
# startup failure, so they cannot ship pointing at another client's infrastructure by accident —
# which otherwise fails SILENTLY (RAG returns null forever, no error, and the coach quietly loses
# its concepts and learning aids). The incumbent leaves this unset. See docs/WHITE_LABEL.md.
CEREBROZEN_STRICT_TENANT=

# --- Resilience (Article 10) ---
CEREBROZEN_LLM_MAX_RETRIES=2
CEREBROZEN_BREAKER_FAILS=5
CEREBROZEN_BREAKER_COOLDOWN_S=30

# --- Routing / feature flags ---
ENABLE_MULTIPATH=true
FORCE_HANDOFF_STAGES=

# --- Observability ---
CEREBROZEN_TRACE=true
LANGSMITH_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# --- Serving ---
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# --- Crisis safety: the second layer (app/graph/crisis_classifier.py) ---
# The lexicon (crisis.py) is the 1ms, free, offline FLOOR — and on its own it catches ~1
# implicit disclosure in 22. The classifier runs on everything it lets through and takes that
# to 20/22 (measured). ON by default: off-by-default for a safety layer is a decision nobody
# remembers making. Costs ~$0.00014 per session against a $0.034 session — a rounding error.
CEREBROZEN_CRISIS_CLASSIFIER=true
CEREBROZEN_CRISIS_MODEL=gpt-5-nano
CEREBROZEN_CRISIS_TIMEOUT_S=4

# Where a detected crisis NOTIFIES A HUMAN. Empty = nobody is told, and every detection logs
# `safety.escalation_not_configured` at ERROR — because a deployment that believes it has a
# safety net and does not is the worst failure mode this product has.
# The payload carries a SIGNAL (user id, session id, which layer fired) and NEVER the
# disclosure. Who is on the other end and what they do is your programme, not our feature.
CEREBROZEN_CRISIS_ESCALATION_URL=
CEREBROZEN_CRISIS_ESCALATION_TIMEOUT_S=5
