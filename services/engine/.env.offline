# CereBroZen — FULLY OFFLINE stack (air-gapped): Postgres + Ollama.
# No OpenAI, no Mongo, no Redis, no S3, no internet.
#
#   docker run -d --name cerebrozen-pg -e POSTGRES_PASSWORD=cerebrozen -e POSTGRES_DB=cerebrozen \
#     -p 5433:5432 pgvector/pgvector:pg16
#   cp .env.offline .env
#   python -m scripts.seed_demo
#   uvicorn app.main:app --port 8000
#
# PROVEN on this stack: repeat-user detection, the 7-day check-in, action cards,
# session state surviving a server restart — all with no external service.

# --- LLM: local Ollama ---------------------------------------------------------
OPENAI_API_KEY=
CEREBROZEN_LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
CEREBROZEN_OLLAMA_MODEL=gemma4:latest
# MUST exceed the worst-case prompt (CH + environment ≈ 26.7K tokens). Ollama DEFAULTS
# TO 4096 and silently truncates — the model then reads the middle of its own instructions.
# 32K is a deliberate floor, not the model's limit: gemma4 advertises 131,072 tokens, but
# the KV cache for that on an 8B model costs VRAM a modest air-gapped box may not have.
# 32K is comfortable — measured 2026-07-17, the biggest composed prompt (CH) is 16.9K, so it
# fits with ~15.8K left for history and output, prefills in 2.1s (7,756 tok/s), and the
# offline eval scores 100% (16/16). Raise it if a long CH session ever truncates; there is
# no need to shrink the prompts to fit it (docs/PROMPTS_SPEC.md §"The budget, measured").
CEREBROZEN_OLLAMA_NUM_CTX=32768
# The Catalog's model ids are OpenAI's; override every agent onto the local model.
CEREBROZEN_MODEL_OVERRIDE=gemma4:latest

# --- Storage: Postgres (checkpointer + all document stores) ---------------------
POSTGRES_URL=postgresql://postgres:cerebrozen@localhost:5433/cerebrozen
MONGO_DB_URL=
REDIS_URL=

# --- RAG: pgvector (no S3, no LanceDB) -----------------------------------------
CEREBROZEN_RAG_BACKEND=pgvector
# Offline embeddings. REQUIRES the Ollama server to be started WITH embeddings enabled
# (a default server refuses /api/embed for every model) and an embedding model pulled:
#     ollama pull nomic-embed-text
# Switching embedder invalidates the index — dimensions differ (1536 vs 768). Re-ingest.
CEREBROZEN_EMBED_PROVIDER=ollama
CEREBROZEN_EMBED_MODEL=nomic-embed-text

# --- Prompts: local workbook (no S3) -------------------------------------------
PROMPT_SOURCE=codebase
PROMPT_WORKBOOK=agent_prompts.xlsx

# --- Auth ----------------------------------------------------------------------
ENV=local
AUTH_DEV_BYPASS=true
