# local | dev | production — production activates the boot-guard
ENV=local

# Postgres in deployments; unset -> local SQLite file (dev only)
DATABASE_URL=postgresql+asyncpg://postgres:pg@localhost:55432/cerebrozen_platform

# Base64-encoded HS512 secret — MUST equal the engine's JWT_SECRET so the
# engine accepts platform-issued tokens.
JWT_SECRET=

CEREBROZEN_ACCESS_TTL_MIN=15
CEREBROZEN_REFRESH_TTL_DAYS=30
CEREBROZEN_INVITATION_TTL_DAYS=14

# Must be false in production (boot-guard enforces it)
CEREBROZEN_SEED_DEV_ADMIN=true
